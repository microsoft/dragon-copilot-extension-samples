{
  "name": "dragon-copilot-cli",
  "version": "1.0.0",
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run copy-resources",
    "copy-resources": "node ./scripts/copy-resources.cjs",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage",
    "clean": "rimraf dist",
    "bundle": "node scripts/bundle.cjs",
    "package:standalone": "node scripts/package-standalone.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "description": "Unified Dragon Copilot Extension and Clinical Application Connector CLI",
  "bin": {
    "dragon-copilot": "dist/cli.js"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "archiver": "^7.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "jest": "^30.3.0",
    "postject": "^1.0.0-alpha.6",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
