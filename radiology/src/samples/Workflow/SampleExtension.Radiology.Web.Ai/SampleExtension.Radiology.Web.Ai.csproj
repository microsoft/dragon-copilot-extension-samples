<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0-windows10.0.26100</TargetFramework>
    <RuntimeIdentifiers>win-x64</RuntimeIdentifiers>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>SampleExtension.Radiology.Web.Ai</RootNamespace>
    <AssemblyName>SampleExtension.Radiology.Web.Ai</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!--
      CA1812: False positive for classes instantiated via DI, model binding, or JSON deserialization.
      CA1848/CA1873: High-performance logging is unnecessary for a simple sample project.
      CA2227: Collection properties need setters for JSON deserialization.
      CS1591: XML doc comments on every public member is excessive for a sample.
    -->
    <NoWarn>CA1812;CA1515;CA1848;CA1873;CS1591;CA2227</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- OpenAPI document generation is built into ASP.NET Core starting with .NET 9. -->
    <PackageReference Include="Azure.AI.OpenAI" />
    <PackageReference Include="Swashbuckle.AspNetCore" />
    <!-- Authentication: Entra ID (Azure AD) JWT bearer via Microsoft Identity Web -->
    <PackageReference Include="Microsoft.Identity.Web" />
    <!-- Foundry Local WinML: on-device model inference via Windows ML (Windows-only). -->
    <PackageReference Include="Microsoft.AI.Foundry.Local.WinML" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\models\Dragon.Copilot.Radiology.Models\Dragon.Copilot.Radiology.Models.csproj" />
  </ItemGroup>

</Project>
